# ─────────────────────────────────────────────────────────────────────────────
# GymPad — environment variables
#
# NOTHING here is required to run locally. With no keys set, the backend uses an
# in-memory store and the deterministic plan engine, so `npm run dev` works out
# of the box. Add keys to turn on real persistence and the live AI coach.
# ─────────────────────────────────────────────────────────────────────────────

# ═══ backend/.env ════════════════════════════════════════════════════════════

PORT=4000
NODE_ENV=development
# Where the frontend runs — used for the CORS allow-list.
FRONTEND_URL=http://localhost:5173

# ─── Supabase (auth + database) ──────────────────────────────────────────────
# Dashboard → Project Settings → API. Leave blank to use the in-memory dev store.
# All three must be set together, or Supabase stays off.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (AI screening + coach) ────────────────────────────────────────
# Blank = the deterministic plan engine runs instead. The app stays fully usable.
ANTHROPIC_API_KEY=
# Safety-critical health screening — most capable model, deliberately not
# cost-optimised, because this decision can tell someone not to train.
ANTHROPIC_SCREENING_MODEL=claude-opus-4-8
# High-volume chat — cheaper tier, near-Opus quality.
ANTHROPIC_COACH_MODEL=claude-sonnet-5

# Reserved for future signed-cookie use; not currently load-bearing.
JWT_SECRET=change-me-to-64-random-chars


# ═══ frontend/.env ═══════════════════════════════════════════════════════════
# Vite only exposes variables prefixed with VITE_ to the browser.
# NEVER put the service-role key here — it would ship to every visitor.

VITE_API_BASE_URL=http://localhost:4000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
